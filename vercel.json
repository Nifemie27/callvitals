{
  "rewrites": [
    { "source": "/((?!assets/|favicon).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/((?!assets/|favicon).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
